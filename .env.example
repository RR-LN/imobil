# KuGava Environment Variables
# Copy this file to .env and fill in your Supabase credentials

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://TEU_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# App Configuration
EXPO_PUBLIC_APP_NAME=KuGava
EXPO_PUBLIC_APP_SCHEME=kugava

# Feature Flags
EXPO_PUBLIC_ENABLE_AFFILIATES=true
EXPO_PUBLIC_ENABLE_BOOKINGS=true

# Sentry Error Monitoring (recommended)
# Get your DSN from https://sentry.io/
#EXPO_PUBLIC_SENTRY_DSN=https://your-public-key@o-id.ingest.sentry.io/project-id
